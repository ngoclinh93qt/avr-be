# AVR Research Formation System - Environment Variables

# Application
APP_ENV=development
DEBUG=true

# LLM Providers (at least one required)
# OpenRouter is the primary/recommended provider
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Optional: Direct provider keys (fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: Local LLM server (OpenAI-compatible)
LOCAL_BASE_URL=
LOCAL_MODEL=

# Default provider and model
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Supabase (required)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ChromaDB for journal search
CHROMA_DB_PATH=./app/data/chroma_journals

# Embedding model for ChromaDB
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Rate limiting
FREE_TIER_DAILY_LIMIT=3
